# ── BioTools Configuration ──

# Port to expose the app on
PORT=5590

# Public URL (set this when behind a reverse proxy like Pangolin, Cloudflare Tunnel, nginx, Traefik, etc.)
# Examples:
#   BASE_URL=https://biotools.yourdomain.com
#   BASE_URL=https://bio.yourdomain.com
BASE_URL=http://localhost:5590

# Maximum upload file size in MB
MAX_UPLOAD_MB=50

# Temporary file directory (inside the container)
TMP_DIR=/app/tmp

# Optional HTTP Basic Auth (leave empty to disable)
ADMIN_USER=
ADMIN_PASS=
